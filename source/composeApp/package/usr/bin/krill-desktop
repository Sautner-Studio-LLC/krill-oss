#!/bin/sh
# Krill Desktop Launcher
# Launches the Krill Desktop application

JAVA_OPTS="-Xmx512m"

# Check for Java
if command -v java >/dev/null 2>&1; then
    JAVA_CMD="java"
elif [ -n "$JAVA_HOME" ] && [ -x "$JAVA_HOME/bin/java" ]; then
    JAVA_CMD="$JAVA_HOME/bin/java"
else
    echo "Error: Java not found. Please install Java 21 or later."
    echo "You can install it with: sudo apt install openjdk-21-jre"
    exit 1
fi

exec "$JAVA_CMD" $JAVA_OPTS -jar /usr/local/lib/krill-desktop/krill-desktop.jar "$@"
