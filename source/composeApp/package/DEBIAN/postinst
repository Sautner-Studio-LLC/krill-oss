#!/bin/sh

set -e

# Krill Desktop is a user-level application (not a system service)
# Create necessary directories in user's home directory

# Get the user who invoked sudo (or current user if not using sudo)
if [ -n "$SUDO_USER" ]; then
    KRILL_USER="$SUDO_USER"
    KRILL_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
else
    KRILL_USER=$(whoami)
    KRILL_HOME="$HOME"
fi

echo "🖥️ Installing Krill Desktop for user: $KRILL_USER"

# Create Krill data directories in user's home
KRILL_DATA_DIR="$KRILL_HOME/.krill"
install -d -o "$KRILL_USER" -g "$KRILL_USER" -m 0750 "$KRILL_DATA_DIR"
install -d -o "$KRILL_USER" -g "$KRILL_USER" -m 0750 "$KRILL_DATA_DIR/data"
install -d -o "$KRILL_USER" -g "$KRILL_USER" -m 0750 "$KRILL_DATA_DIR/data/nodes"
install -d -o "$KRILL_USER" -g "$KRILL_USER" -m 0750 "$KRILL_DATA_DIR/logs"
install -d -o "$KRILL_USER" -g "$KRILL_USER" -m 0750 "$KRILL_DATA_DIR/trusted"
install -d -o "$KRILL_USER" -g "$KRILL_USER" -m 0750 "$KRILL_DATA_DIR/config"

# Create desktop entry for the application
DESKTOP_FILE="/usr/share/applications/krill-desktop.desktop"

cat > "$DESKTOP_FILE" << 'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=Krill Desktop
Comment=Krill Desktop Control Application
Exec=/usr/bin/krill-desktop
Icon=/usr/share/icons/krill-desktop.png
Terminal=false
Categories=Utility;Network;
StartupNotify=true
EOF

chmod 644 "$DESKTOP_FILE"

# Update desktop database if available
if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database /usr/share/applications || true
fi

echo "🖥️ Krill Desktop installed successfully."
echo "   Data directory: $KRILL_DATA_DIR"
echo "   You can launch it from your application menu or by running: krill-desktop"

exit 0
