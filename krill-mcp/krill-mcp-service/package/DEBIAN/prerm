#!/bin/sh

set -e

case "$1" in
    remove|upgrade)
        if [ -x "/bin/systemctl" ]; then
            systemctl stop krill-mcp.service || true
            systemctl disable krill-mcp.service || true
            systemctl daemon-reload || true
        fi
        ;;
    failed-upgrade)
        ;;
    *)
        ;;
esac

exit 0
